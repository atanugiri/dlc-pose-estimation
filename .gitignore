# .gitignore for dlc-pose-estimation
# Ignore common Python, Jupyter, macOS, IDE, and DeepLabCut/model outputs

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
env/
venv/
.venv/
ENV/
.env/

# Conda environments (local)
.conda/

# Jupyter Notebook checkpoints and outputs
.ipynb_checkpoints/
*.nbconvert.ipynb

# DeepLabCut / model outputs and large artifacts
results/
models/
snapshots/
*.h5
*_snapshot_*.h5
*.ckpt
*.pt
*.csv
*.pickle
*.pkl
*.mat
*.zip*
*.png
*.tar

# DeepLabCut specific files
evaluation-results/
training-datasets/
*.yaml.bak
config.yaml.bak
*.avi
*.mp4
*.mov
*.m4v

# Large data files
*.tar.gz
*.7z
*.rar

# macOS
.DS_Store
**/.DS_Store

# Windows
Thumbs.db
*.docx

# IDEs and editors
.vscode/
.idea/
*.sublime-workspace
*.sublime-project

# Logs and temporary files
*.log
*.tmp
tmp/
temp/

# Build / packaging
build/
dist/
*.egg-info/

# Coverage, test artifacts
htmlcov/
.coverage

# Sphinx build
_build/

# Caches and backup files
.cache/
*~

# md files
DeepLabCut_Installation_Guide.md
hpc_to_wsl_transfer.md
preprocessing_steps.md